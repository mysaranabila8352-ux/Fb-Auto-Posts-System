# Rename this file to .env and fill in your values

# --- Facebook credentials (optional) ---
# Leave both blank to run in Mock Mode: posts are simulated (fake success,
# logged normally) instead of actually calling the Facebook Graph API.
# Fill both in once you're ready to publish to a real Page.

# Facebook Page access token (long-lived, from Graph API Explorer or a System User in Meta Business Suite)
FB_PAGE_ACCESS_TOKEN=
# The numeric ID of the Facebook Page you want to post to
FB_PAGE_ID=

# Force Mock Mode on even if the above are filled in (useful for testing). Default: false
MOCK_MODE=false

# Graph API version to call
FB_GRAPH_API_VERSION=v20.0

# Port for the dashboard/backend server
PORT=3000

# How often the scheduler checks for due posts (cron expression). Default: every minute
SCHEDULER_CRON=* * * * *
